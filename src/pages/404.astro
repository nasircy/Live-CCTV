---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = '/Live-CCTV';
---

<BaseLayout title="404">
  <div class="not-found">
    <h1>404</h1>
    <p>ページが見つかりません</p>
    <a href={`${base}/`} class="back-link">返回首頁 &rarr;</a>
  </div>

  <style>
    .not-found {
      text-align: center; padding: 6rem 0;
    }
    h1 {
      font-size: 4rem; font-weight: 400; color: var(--border);
      margin-bottom: 0.5rem; letter-spacing: 0.1em;
    }
    p { color: var(--text-dim); margin-bottom: 2rem; font-size: 0.88rem; }
    .back-link {
      font-size: 0.82rem; color: var(--accent);
      border-bottom: 1px solid transparent; transition: border-color 0.2s;
    }
    .back-link:hover { border-bottom-color: var(--accent); text-decoration: none; }
  </style>
</BaseLayout>
