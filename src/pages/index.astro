---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = '/Live-CCTV';
---

<BaseLayout title="首頁">
  <section class="hero">
    <p class="hero-label">台湾即時映像監視システム</p>
    <h1>NY-Live-CCTV</h1>
    <p class="hero-desc">彙整全台 11,914 路即時影像，涵蓋國道、省道、市區道路、水利署防災、旅遊景點等公開 CCTV 資料</p>
    <div class="hero-actions">
      <a href={`${base}/regions`} class="btn">瀏覽區域</a>
      <a href={`${base}/search`} class="btn btn-outline">搜尋攝影機</a>
    </div>
  </section>

  <section class="stats">
    <div class="stat"><span class="stat-n">11,914</span><span class="stat-l">台攝影機</span></div>
    <div class="stat"><span class="stat-n">18</span><span class="stat-l">個縣市</span></div>
    <div class="stat"><span class="stat-n">即時</span><span class="stat-l">影像串流</span></div>
  </section>

  <section class="features">
    <div class="feature-grid">
      <a href={`${base}/regions`} class="feature-card">
        <span class="feature-num">01</span>
        <h3>エリア</h3>
        <p>依縣市分類，瀏覽各地即時影像</p>
      </a>
      <a href={`${base}/map`} class="feature-card">
        <span class="feature-num">02</span>
        <h3>位置検索</h3>
        <p>自動偵測附近攝影機，隨行移動更新</p>
      </a>
      <a href={`${base}/regions`} class="feature-card">
        <span class="feature-num">03</span>
        <h3>ライブ映像</h3>
        <p>直接連接政府 CCTV 來源，觀看即時路況</p>
      </a>
      <a href={`${base}/map`} class="feature-card">
        <span class="feature-num">04</span>
        <h3>接近アラート</h3>
        <p>接近攝影機路口時自動彈出提醒</p>
      </a>
    </div>
  </section>

  <style>
    .hero {
      text-align: center; padding: 4rem 0 3rem;
    }
    .hero-label {
      font-size: 0.72rem; letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--text-dim); margin-bottom: 1rem;
    }
    .hero h1 {
      font-size: 2.8rem; font-weight: 400; margin-bottom: 1.5rem;
      letter-spacing: 0.12em; color: var(--text);
    }
    .hero-desc {
      color: var(--text-muted); font-size: 0.88rem; max-width: 480px;
      margin: 0 auto 2.5rem; line-height: 2;
    }
    .hero-actions { display: flex; gap: 0.75rem; justify-content: center; }

    .btn {
      display: inline-block; padding: 0.6rem 2rem;
      font-size: 0.82rem; letter-spacing: 0.08em;
      border: 1px solid var(--text); background: var(--text); color: var(--bg);
      transition: all 0.2s; text-decoration: none;
    }
    .btn:hover { background: var(--accent); border-color: var(--accent); color: #fff; text-decoration: none; }
    .btn-outline { background: transparent; color: var(--text); }
    .btn-outline:hover { background: var(--text); color: var(--bg); }

    .stats {
      display: grid; grid-template-columns: repeat(3, 1fr);
      border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
      margin: 0 0 3rem;
    }
    .stat {
      text-align: center; padding: 2rem 1rem;
      border-right: 1px solid var(--border-light);
    }
    .stat:last-child { border-right: none; }
    .stat-n {
      display: block; font-size: 1.5rem; font-family: var(--font-serif);
      font-weight: 400; letter-spacing: 0.05em; margin-bottom: 0.25rem;
    }
    .stat-l {
      display: block; font-size: 0.7rem; color: var(--text-dim);
      letter-spacing: 0.15em;
    }

    .features { margin-bottom: 2rem; }
    .feature-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; background: var(--border); border: 1px solid var(--border); }
    .feature-card {
      background: var(--surface); padding: 2rem;
      text-decoration: none; color: inherit;
      transition: background 0.2s;
      display: block;
    }
    .feature-card:hover { background: var(--accent-light); text-decoration: none; }
    .feature-num {
      font-size: 0.65rem; color: var(--text-dim); font-family: var(--font-mono);
      letter-spacing: 0.1em; display: block; margin-bottom: 0.75rem;
    }
    .feature-card h3 {
      font-size: 1rem; margin-bottom: 0.5rem; font-weight: 400;
    }
    .feature-card p { font-size: 0.78rem; color: var(--text-muted); line-height: 1.7; }

    @media (max-width: 640px) {
      .hero h1 { font-size: 2rem; }
      .stats { grid-template-columns: 1fr; }
      .stat { border-right: none; border-bottom: 1px solid var(--border-light); }
      .stat:last-child { border-bottom: none; }
      .feature-grid { grid-template-columns: 1fr; }
    }
  </style>
</BaseLayout>
