---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = '/Live-CCTV';
---

<BaseLayout title="撮影機検索">
  <section class="page-header">
    <a href={`${base}/`} class="back">&larr; 戻る</a>
    <p class="page-label">CAMERA SEARCH</p>
    <h1>撮影機検索</h1>
    <p class="page-desc">地名、路名、景點で即時映像を検索</p>
  </section>

  <div class="search-box">
    <input type="text" id="searchInput" placeholder="板橋、國道一號、三重..." autocomplete="off" />
    <span class="search-icon">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
    </span>
  </div>

  <div class="search-stats" id="searchStats"></div>
  <div class="cam-grid" id="searchResults"></div>

  <style>
    .page-header { margin-bottom: 2rem; }
    .back {
      font-size: 0.72rem; color: var(--text-dim); display: inline-block;
      margin-bottom: 1rem; letter-spacing: 0.05em;
    }
    .back:hover { color: var(--accent); }
    .page-label {
      font-size: 0.65rem; letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--text-dim); margin-bottom: 0.5rem;
    }
    h1 { font-size: 1.6rem; font-weight: 400; margin-bottom: 0.25rem; }
    .page-desc { color: var(--text-muted); font-size: 0.82rem; }

    .search-box {
      position: relative; margin-bottom: 1.5rem;
    }
    .search-box input {
      width: 100%; padding: 0.8rem 1rem 0.8rem 2.5rem;
      font-size: 0.9rem; font-family: var(--font);
      border: 1px solid var(--border); background: var(--surface);
      color: var(--text); outline: none;
      transition: border-color 0.2s;
    }
    .search-box input:focus { border-color: var(--accent); }
    .search-box input::placeholder { color: var(--text-dim); }
    .search-icon {
      position: absolute; left: 0.8rem; top: 50%; transform: translateY(-50%);
      color: var(--text-dim); display: flex; align-items: center;
    }

    .search-stats {
      font-size: 0.75rem; color: var(--text-dim);
      margin-bottom: 1rem; min-height: 1.2em;
    }

    .cam-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1px; background: var(--border); border: 1px solid var(--border);
    }

    .cam-card {
      background: var(--surface); overflow: hidden;
      transition: background 0.2s;
    }
    .cam-card:hover { background: #faf9f7; }
    .cam-preview {
      width: 100%; aspect-ratio: 16/9;
      background: #eae7e1; position: relative; overflow: hidden;
    }
    .cam-preview img, .cam-preview .cam-video {
      width: 100%; height: 100%; object-fit: cover;
    }
    .cam-nosig {
      display: flex; align-items: center; justify-content: center;
      height: 100%; color: var(--text-dim);
      font-size: 0.65rem; letter-spacing: 0.1em;
      font-family: var(--font-mono); flex-direction: column; gap: 0.4rem;
    }
    .cam-nosig svg { opacity: 0.4; }
    .cam-live {
      position: absolute; top: 10px; left: 10px; z-index: 2;
      background: rgba(255,255,255,0.88); backdrop-filter: blur(4px);
      padding: 2px 8px; font-size: 0.58rem; letter-spacing: 0.15em;
      color: var(--red); font-family: var(--font-mono); font-weight: 500;
    }
    .cam-info { padding: 1rem 1.25rem; }
    .cam-name {
      font-size: 0.82rem; font-weight: 500;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      margin-bottom: 0.2rem;
    }
    .cam-city {
      font-size: 0.7rem; color: var(--text-dim);
      margin-bottom: 0.75rem;
    }
    .cam-actions { display: flex; gap: 0.5rem; }
    .cam-link {
      font-size: 0.7rem; color: var(--accent);
      letter-spacing: 0.05em; padding: 3px 0;
      border-bottom: 1px solid transparent; transition: border-color 0.2s;
    }
    .cam-link:hover { border-bottom-color: var(--accent); text-decoration: none; }

    .no-result {
      grid-column: 1 / -1; text-align: center;
      padding: 4rem 2rem; color: var(--text-dim);
      font-size: 0.85rem; background: var(--surface);
    }

    @media (max-width: 640px) {
      .cam-grid { grid-template-columns: 1fr; }
    }
  </style>

  <script src="https://cdn.jsdelivr.net/npm/hls.js@1"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      var input = document.getElementById('searchInput');
      var results = document.getElementById('searchResults');
      var stats = document.getElementById('searchStats');
      var cameras = null;

      function loadCameras() {
        if (cameras) return Promise.resolve(cameras);
        return fetch('/Live-CCTV/cameras_thumb.json')
          .then(function(r) { return r.json(); })
          .then(function(data) { cameras = data; return data; });
      }

      function escHtml(s) {
        return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
      }

      function showNoSignal(el) {
        var d = document.createElement('div');
        d.className = 'cam-nosig';
        d.innerHTML = '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M23 7l-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg><span>NO SIGNAL</span>';
        el.parentNode.replaceChild(d, el);
      }

      function renderCam(c) {
        var city = c.city || c.region || '';
        var media;
        if (c.type === 'hls') {
          media = '<video class="cam-video" data-src="' + escHtml(c.url || '') + '" muted autoplay loop playsinline></video>';
        } else {
          media = '<img class="cam-img" src="' + escHtml(c.url || '') + '" alt="" loading="lazy" />';
        }
        return '<div class="cam-card">' +
          '<div class="cam-preview">' +
            '<span class="cam-live">LIVE</span>' +
            media +
          '</div>' +
          '<div class="cam-info">' +
            '<div class="cam-name" title="' + escHtml(c.name || '') + '">' + escHtml(c.name || '未命名') + '</div>' +
            '<div class="cam-city">' + escHtml(city) + '</div>' +
            '<div class="cam-actions">' +
              '<a href="/Live-CCTV/camera/#' + (c.id || '') + '" class="cam-link">映像を見る</a>' +
            '</div>' +
          '</div>' +
        '</div>';
      }

      function doSearch() {
        var q = input.value.trim();
        if (!q) {
          results.innerHTML = '';
          stats.textContent = '';
          return;
        }

        loadCameras().then(function(data) {
          var ql = q.toLowerCase();
          var terms = ql.split(/\s+/);

          var filtered = data.filter(function(c) {
            var hay = ((c.name || '') + ' ' + (c.region || '') + ' ' + (c.city || '')).toLowerCase();
            return terms.every(function(t) { return hay.indexOf(t) !== -1; });
          });

          stats.textContent = filtered.length + ' 台のカメラ';

          if (filtered.length === 0) {
            results.innerHTML = '<div class="no-result">該當するカメラが見つかりません</div>';
            return;
          }

          var html = '';
          var shown = filtered.slice(0, 100);
          for (var i = 0; i < shown.length; i++) {
            html += renderCam(shown[i]);
          }

          if (filtered.length > 100) {
            html += '<div class="no-result">上位 100 件表示（全 ' + filtered.length + ' 件）</div>';
          }

          results.innerHTML = html;
          initSearchMedia();
        });
      }

      var timer;
      input.addEventListener('input', function() {
        clearTimeout(timer);
        timer = setTimeout(doSearch, 150);
      });

      loadCameras();
      input.focus();

      var searchHlsInited = new WeakSet();
      var searchActiveHls = 0;
      var SEARCH_MAX_HLS = 6;

      function initSearchMedia() {
        document.querySelectorAll('#searchResults .cam-img').forEach(function(img) {
          if (searchHlsInited.has(img)) return;
          searchHlsInited.add(img);
          img.onerror = function() { img.remove(); showNoSignal(img.parentNode); };
        });

        document.querySelectorAll('#searchResults .cam-video[data-src]').forEach(function(video) {
          if (searchHlsInited.has(video)) return;
          if (searchActiveHls >= SEARCH_MAX_HLS) return;
          searchHlsInited.add(video);
          searchActiveHls++;

          if (typeof Hls !== 'undefined' && Hls.isSupported()) {
            var hls = new Hls({ enableWorker: true, lowLatencyMode: false, maxBufferLength: 10, startFragPrefetch: true, maxMaxBufferLength: 20 });
            hls.loadSource(video.dataset.src);
            hls.attachMedia(video);
            hls.on(Hls.Events.MANIFEST_PARSED, function() { video.play().catch(function(){}); });
            hls.on(Hls.Events.ERROR, function(e, data) {
              if (data.fatal) { hls.destroy(); searchActiveHls--; video.remove(); showNoSignal(video.parentNode); }
            });
          } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
            video.src = video.dataset.src;
            video.play().catch(function(){});
          } else {
            searchActiveHls--;
            video.remove();
            showNoSignal(video.parentNode);
          }
        });
      }
    });
  </script>
</BaseLayout>
