---
import BaseLayout from '../layouts/BaseLayout.astro';
import regions from '../data/regions.json';
const base = '/NY-Live-CCTV';

const regionOrder = [
  "國道", "國道一號", "國道二號", "國道三號", "國道四號", "國道五號",
  "國道六號", "國道八號", "國道十號",
  "快速公路-台61線", "快速公路-台62線", "快速公路-台64線",
  "快速公路-台65線", "快速公路-台66線", "快速公路-台68線",
  "快速公路-台72線", "快速公路-台74線", "快速公路-台76線",
  "快速公路-台78線", "快速公路-台82線", "快速公路-台84線",
  "快速公路-台86線", "快速公路-台88線",
  "省道", "市區道路",
  "水利署防災", "科學園區", "旅遊景點",
  "其他"
];

const sorted = Object.entries(regions).sort((a, b) => {
  const ia = regionOrder.indexOf(a[0]);
  const ib = regionOrder.indexOf(b[0]);
  return (ia === -1 ? 999 : ia) - (ib === -1 ? 999 : ib);
});
---

<BaseLayout title="區域瀏覽">
  <h1>區域瀏覽</h1>
  <p class="page-desc">選擇分類檢視各區域的即時攝影機</p>

  <div class="region-grid">
    {sorted.map(([name, info]) => (
      <a href={`${base}/region/${encodeURIComponent(name)}`} class="region-card">
        <div class="region-count">{info.count.toLocaleString()}</div>
        <div class="region-name">{name}</div>
        <div class="region-bar">
          <div class="region-bar-fill" style={`width: ${Math.min(100, (info.count / 4000) * 100)}%`}></div>
        </div>
      </a>
    ))}
  </div>

  <style>
    h1 { margin-bottom: 0.25rem; }
    .page-desc { color: var(--color-muted); margin-bottom: 2rem; font-size: 0.9rem; }
    .region-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; }
    .region-card {
      background: var(--color-surface); border: 1px solid var(--color-border);
      border-radius: 12px; padding: 1.25rem;
      text-decoration: none; color: inherit; transition: border-color 0.2s, transform 0.2s;
    }
    .region-card:hover { border-color: var(--color-accent); transform: translateY(-2px); text-decoration: none; }
    .region-count {
      font-size: 1.6rem; font-weight: 700; font-variant-numeric: tabular-nums;
      color: var(--color-accent); margin-bottom: 4px;
    }
    .region-name { font-size: 0.9rem; margin-bottom: 0.75rem; }
    .region-bar { height: 3px; background: var(--color-border); border-radius: 2px; overflow: hidden; }
    .region-bar-fill { height: 100%; background: var(--color-accent); border-radius: 2px; transition: width 0.5s; }
  </style>
</BaseLayout>
