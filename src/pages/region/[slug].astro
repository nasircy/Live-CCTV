---
import fs from 'node:fs';
import path from 'node:path';
import BaseLayout from '../../layouts/BaseLayout.astro';
import regions from '../../data/regions.json';
const base = '/Live-CCTV';

export function getStaticPaths() {
  const entries = Object.entries(regions);
  return entries.map(([name], i) => ({
    params: { slug: String(i) },
    props: { regionName: name, regionInfo: regions[name] }
  }));
}

const { regionName, regionInfo } = Astro.props;
const dataFile = regionInfo.file;
const camCount = regionInfo.count;
const dataDir = path.join(process.cwd(), 'src', 'data');
const cameras = JSON.parse(fs.readFileSync(path.join(dataDir, dataFile), 'utf-8'));
---

<BaseLayout title={regionName}>
  <section class="page-header">
    <a href={`${base}/regions`} class="back">&larr; 返回</a>
    <p class="page-label">CAMERA</p>
    <h1>{regionName}</h1>
    <p class="page-desc">{camCount.toLocaleString()} 台攝影機</p>
  </section>

  <div class="cam-grid">
    {cameras.map(cam => (
      <div class="cam-card">
        <div class="cam-preview">
          <span class="cam-live">LIVE</span>
          <img
            src={cam.url}
            alt={cam.name}
            loading="lazy"
            onerror="this.outerHTML='<div class=&apos;cam-nosig&apos;>NO SIGNAL</div>'"
          />
        </div>
        <div class="cam-info">
          <div class="cam-name" title={cam.name}>{cam.name}</div>
          <div class="cam-city">{cam.city || ''}</div>
          <div class="cam-actions">
            <a href={cam.url} target="_blank" rel="noopener" class="cam-link">觀看</a>
          </div>
        </div>
      </div>
    ))}
  </div>

  <style>
    .page-header { margin-bottom: 2.5rem; }
    .back {
      font-size: 0.72rem; color: var(--text-dim); display: inline-block;
      margin-bottom: 1rem; letter-spacing: 0.05em;
    }
    .back:hover { color: var(--accent); }
    .page-label {
      font-size: 0.65rem; letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--text-dim); margin-bottom: 0.5rem;
    }
    h1 { font-size: 1.6rem; font-weight: 400; margin-bottom: 0.25rem; }
    .page-desc { color: var(--text-muted); font-size: 0.82rem; }

    .cam-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1px; background: var(--border); border: 1px solid var(--border); }

    .cam-card {
      background: var(--surface); overflow: hidden;
      transition: background 0.2s;
    }
    .cam-card:hover { background: #faf9f7; }
    .cam-preview {
      width: 100%; aspect-ratio: 16/9;
      background: #eae7e1; position: relative; overflow: hidden;
    }
    .cam-preview img {
      width: 100%; height: 100%; object-fit: cover;
    }
    .cam-nosig {
      display: flex; align-items: center; justify-content: center;
      height: 100%; color: var(--text-dim); font-size: 0.7rem;
      letter-spacing: 0.15em; font-family: var(--font-mono);
    }
    .cam-live {
      position: absolute; top: 10px; left: 10px; z-index: 2;
      background: rgba(255,255,255,0.88); backdrop-filter: blur(4px);
      padding: 2px 8px; font-size: 0.58rem; letter-spacing: 0.15em;
      color: var(--red); font-family: var(--font-mono); font-weight: 500;
    }
    .cam-info { padding: 1rem 1.25rem; }
    .cam-name {
      font-size: 0.82rem; font-weight: 500;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      margin-bottom: 0.2rem;
    }
    .cam-city {
      font-size: 0.7rem; color: var(--text-dim);
      margin-bottom: 0.75rem;
    }
    .cam-actions { display: flex; gap: 0.5rem; }
    .cam-link {
      font-size: 0.7rem; color: var(--accent);
      letter-spacing: 0.05em; padding: 3px 0;
      border-bottom: 1px solid transparent; transition: border-color 0.2s;
    }
    .cam-link:hover { border-bottom-color: var(--accent); text-decoration: none; }

    @media (max-width: 640px) {
      .cam-grid { grid-template-columns: 1fr; }
    }
  </style>
</BaseLayout>
