---
import BaseLayout from '../../layouts/BaseLayout.astro';
import regions from '../../data/regions.json';
const base = '/Live-CCTV';

export function getStaticPaths() {
  return Object.keys(regions).map(name => ({
    params: { slug: encodeURIComponent(name) }
  }));
}

const slug = Astro.params.slug;
const regionName = decodeURIComponent(slug);
const regionInfo = regions[regionName];

if (!regionInfo) {
  return Astro.redirect('/404');
}

const dataFile = regionInfo.file;
const camCount = regionInfo.count;
---

<BaseLayout title={regionName}>
  <div class="region-header">
    <a href={`${base}/regions`} class="back-link">&#8592; 返回區域列表</a>
    <h1>{regionName}</h1>
    <p class="cam-count">{camCount.toLocaleString()} 台攝影機</p>
  </div>

  <div class="cam-grid" id="camGrid">
    <div class="loading-cams">載入中...</div>
  </div>

  <style>
    .region-header { margin-bottom: 1.5rem; }
    .back-link { color: var(--text-dim); font-size: 0.8rem; display: inline-block; margin-bottom: 0.5rem; }
    .back-link:hover { color: var(--accent); }
    h1 { margin-bottom: 0.25rem; font-weight: 600; font-size: 1.4rem; }
    .cam-count { color: var(--text-dim); font-size: 0.85rem; font-family: var(--font-mono); }
    .cam-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 1rem; }
    .loading-cams { grid-column: 1 / -1; text-align: center; padding: 3rem; color: var(--text-dim); }

    .cam-card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--radius); overflow: hidden; transition: border-color 0.2s, box-shadow 0.2s;
    }
    .cam-card:hover { border-color: var(--border-bright); box-shadow: 0 0 20px rgba(0,0,0,0.3); }
    .cam-preview {
      width: 100%; aspect-ratio: 16/9;
      background: #05080c; position: relative; overflow: hidden;
    }
    .cam-preview::after {
      content: ''; position: absolute; inset: 0;
      background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,212,170,0.025) 2px, rgba(0,212,170,0.025) 4px);
      pointer-events: none;
    }
    .cam-preview img {
      width: 100%; height: 100%; object-fit: cover;
      transition: opacity 0.3s;
    }
    .cam-preview .cam-placeholder {
      display: flex; align-items: center; justify-content: center;
      height: 100%; color: var(--text-dim); font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 2px;
    }
    .cam-card .cam-tag {
      position: absolute; top: 8px; left: 8px;
      display: flex; align-items: center; gap: 5px;
      background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);
      padding: 2px 8px; border-radius: 4px; font-size: 0.65rem; font-family: var(--font-mono); color: var(--accent);
    }
    .cam-card .cam-tag .dot {
      width: 5px; height: 5px; border-radius: 50%; background: var(--green);
      box-shadow: 0 0 6px rgba(63, 201, 138, 0.6);
    }
    .cam-body { padding: 0.75rem 1rem; display: flex; align-items: center; gap: 0.75rem; }
    .cam-body .cam-name-wrap { flex: 1; min-width: 0; }
    .cam-name {
      font-size: 0.8rem; font-weight: 500;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .cam-meta { font-size: 0.7rem; color: var(--text-dim); margin-top: 2px; }
    .cam-actions { display: flex; gap: 6px; flex-shrink: 0; }
    .cam-btn {
      padding: 4px 10px; border-radius: 4px; font-size: 0.7rem;
      border: 1px solid var(--border-bright); background: transparent;
      color: var(--text-muted); cursor: pointer; transition: all 0.15s;
      text-decoration: none; display: inline-block; font-family: inherit;
    }
    .cam-btn:hover { border-color: var(--accent); color: var(--accent); text-decoration: none; }
    .cam-btn-primary { background: var(--accent); color: var(--bg); border-color: var(--accent); }
    .cam-btn-primary:hover { background: #33ddb5; color: var(--bg); }

    @media (max-width: 640px) {
      .cam-grid { grid-template-columns: 1fr; }
    }
  </style>

  <script>
    document.addEventListener('astro:page-load', async () => {
      var grid = document.getElementById('camGrid');
      if (!grid) return;

      try {
        var resp = await fetch('/Live-CCTV/data/' + dataFile);
        var cams = await resp.json();

        if (cams.length === 0) {
          grid.innerHTML = '<div class="loading-cams">無攝影機資料</div>';
          return;
        }

        grid.innerHTML = cams.map(function(cam) {
          var mapUrl = 'https://www.google.com/maps?q=' + cam.lat + ',' + cam.lng;
          var streamUrl = cam.url;
          return '' +
            '<div class="cam-card">' +
              '<div class="cam-preview">' +
                '<div class="cam-tag"><span class="dot"></span>LIVE</div>' +
                '<img src="' + streamUrl + '" alt="' + cam.name + '" loading="lazy" onerror="this.parentElement.innerHTML=\'<div class=\\\\\'cam-placeholder\\\\\'>NO SIGNAL</div>\'">' +
              '</div>' +
              '<div class="cam-body">' +
                '<div class="cam-name-wrap">' +
                  '<div class="cam-name" title="' + cam.name + '">' + cam.name + '</div>' +
                  '<div class="cam-meta">' + (cam.city || '') + ' &middot; ' + cam.lat.toFixed(4) + ', ' + cam.lng.toFixed(4) + '</div>' +
                '</div>' +
                '<div class="cam-actions">' +
                  '<a href="' + streamUrl + '" target="_blank" rel="noopener" class="cam-btn cam-btn-primary">觀看</a>' +
                  '<a href="' + mapUrl + '" target="_blank" rel="noopener" class="cam-btn">地圖</a>' +
                '</div>' +
              '</div>' +
            '</div>';
        }).join('');
      } catch (e) {
        grid.innerHTML = '<div class="loading-cams">載入失敗: ' + e.message + '</div>';
      }
    });
  </script>
</BaseLayout>
