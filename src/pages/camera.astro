---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = '/Live-CCTV';
---

<BaseLayout title="カメラ">
  <div class="cam-full" id="camFull">
    <div class="cam-full-header">
      <a href={`${base}/`} class="back" id="backBtn">&larr; 戻る</a>
      <div class="cam-full-info">
        <div class="cam-full-name" id="camName">読み込み中...</div>
        <div class="cam-full-city" id="camCity"></div>
      </div>
    </div>
    <div class="cam-full-preview" id="camPreview">
      <span class="cam-live">LIVE</span>
    </div>
    <div class="cam-full-meta" id="camMeta"></div>
  </div>

  <style is:inline>
    .cam-full { max-width: 960px; margin: 0 auto; }
    .cam-full-header {
      display: flex; align-items: center; gap: 1rem;
      margin-bottom: 1rem;
    }
    .cam-full-header .back {
      font-size: 0.78rem; color: var(--text-dim);
      text-decoration: none; flex-shrink: 0;
    }
    .cam-full-header .back:hover { color: var(--accent); }
    .cam-full-info { min-width: 0; }
    .cam-full-name {
      font-size: 1rem; font-weight: 500; color: var(--text);
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .cam-full-city { font-size: 0.75rem; color: var(--text-dim); margin-top: 2px; }
    .cam-full-preview {
      width: 100%; aspect-ratio: 16/9;
      background: #1a1a1a; position: relative; overflow: hidden;
      border: 1px solid var(--border);
    }
    .cam-full-preview video,
    .cam-full-preview img {
      width: 100%; height: 100%; object-fit: contain;
      display: block; background: #1a1a1a;
    }
    .cam-full-preview .cam-nosig {
      display: flex; align-items: center; justify-content: center;
      height: 100%; color: #888;
      font-size: 0.75rem; letter-spacing: 0.15em;
      font-family: var(--font-mono); flex-direction: column; gap: 0.5rem;
    }
    .cam-full-preview .cam-nosig svg { opacity: 0.4; }
    .cam-full-preview .cam-live {
      position: absolute; top: 12px; left: 12px; z-index: 2;
      background: rgba(255,255,255,0.88); backdrop-filter: blur(4px);
      padding: 3px 10px; font-size: 0.6rem; letter-spacing: 0.15em;
      color: var(--red); font-family: var(--font-mono); font-weight: 500;
    }
    .cam-full-meta {
      padding: 1rem 0; font-size: 0.75rem; color: var(--text-dim);
      display: flex; gap: 1.5rem; flex-wrap: wrap;
    }
    .cam-full-meta span { display: inline-flex; align-items: center; gap: 4px; }
  </style>

  <script is:inline src="https://cdn.jsdelivr.net/npm/hls.js@1"></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      var camName = document.getElementById('camName');
      var camCity = document.getElementById('camCity');
      var camPreview = document.getElementById('camPreview');
      var camMeta = document.getElementById('camMeta');
      var backBtn = document.getElementById('backBtn');

      var cctvSvg = '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M23 7l-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>';

      function showNoSignal(parent) {
        var d = document.createElement('div');
        d.className = 'cam-nosig';
        d.innerHTML = cctvSvg + '<span>NO SIGNAL</span>';
        parent.appendChild(d);
      }

      function loadCamera(index) {
        fetch('/Live-CCTV/cameras_thumb.json')
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var cam = data[index];
            if (!cam) {
              camName.textContent = 'カメラが見つかりません';
              return;
            }

            document.title = cam.name + ' | ライブ・CCTV';
            camName.textContent = cam.name || '未命名';
            camCity.textContent = [cam.city, cam.region].filter(Boolean).join(' · ');

            var isHls = cam.type === 'hls' || (cam.url && cam.url.indexOf('.m3u8') !== -1);

            if (isHls) {
              var video = document.createElement('video');
              video.muted = true;
              video.autoplay = true;
              video.loop = true;
              video.playsInline = true;
              video.controls = true;
              camPreview.appendChild(video);

              if (typeof Hls !== 'undefined' && Hls.isSupported()) {
                var hls = new Hls({ enableWorker: true, lowLatencyMode: false, maxBufferLength: 10, startFragPrefetch: true, maxMaxBufferLength: 30 });
                hls.loadSource(cam.url);
                hls.attachMedia(video);
                hls.on(Hls.Events.MANIFEST_PARSED, function() { video.play().catch(function(){}); });
                hls.on(Hls.Events.ERROR, function(e, data) {
                  if (data.fatal) { hls.destroy(); showNoSignal(camPreview); video.remove(); }
                });
              } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
                video.src = cam.url;
                video.play().catch(function(){});
              } else {
                showNoSignal(camPreview);
              }
            } else {
              var img = document.createElement('img');
              img.alt = cam.name || '';
              img.onload = function() {
                var refreshImg = document.createElement('img');
                refreshImg.style.cssText = 'width:100%;height:100%;object-fit:contain;display:block;background:#1a1a1a';
                refreshImg.src = cam.url + '?t=' + Date.now();
                refreshImg.onerror = function() { showNoSignal(camPreview); refreshImg.remove(); };
                camPreview.appendChild(refreshImg);
                setInterval(function() {
                  refreshImg.src = cam.url + '?t=' + Date.now();
                }, 10000);
              };
              img.onerror = function() { img.remove(); showNoSignal(camPreview); };
              img.src = cam.url;
              camPreview.appendChild(img);
            }

            var metaHtml = '';
            if (cam.region) metaHtml += '<span>📍 ' + cam.region + '</span>';
            if (cam.city && cam.city !== cam.region) metaHtml += '<span>🏘️ ' + cam.city + '</span>';
            if (cam.url) metaHtml += '<span>🔗 ' + cam.url.replace(/https?:\/\//, '').substring(0, 40) + '</span>';
            camMeta.innerHTML = metaHtml;
          });
      }

      function init() {
        var hash = window.location.hash.replace('#', '');
        var index = parseInt(hash, 10);
        if (!isNaN(index)) {
          loadCamera(index);
        } else {
          camName.textContent = 'カメラIDが無効です';
        }
      }

      init();
    });
  </script>
</BaseLayout>
