---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = '/Live-CCTV';
---

<BaseLayout title="即時定位">
  <section class="page-header">
    <p class="page-label">NEARBY CAMERAS</p>
    <h1>附近のカメラ</h1>
    <p class="page-desc">GPSを起動して、近くの即時映像を検出します</p>
  </section>

  <div class="gps-bar">
    <div class="gps-status">
      <span class="gps-dot" id="gpsDot"></span>
      <span id="gpsText">位置取得中...</span>
    </div>
    <div class="gps-radius">
      <span>検出範囲：<strong id="radiusLabel">300</strong>m</span>
      <input type="range" id="radiusSlider" min="100" max="2000" value="300" step="50" />
    </div>
    <div class="gps-nearby">周辺：<strong id="nearbyCount">0</strong>台</div>
    <button class="gps-refresh" id="refreshBtn">再読込</button>
  </div>

  <div class="cam-grid" id="nearbyList">
    <div class="empty-state">位置情報を取得中...</div>
  </div>

  <div class="toast-container" id="toastContainer"></div>

  <style>
    .page-header { margin-bottom: 2rem; }
    .page-label {
      font-size: 0.65rem; letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--text-dim); margin-bottom: 0.5rem;
    }
    h1 { font-size: 1.6rem; font-weight: 400; margin-bottom: 0.25rem; }
    .page-desc { color: var(--text-muted); font-size: 0.82rem; }

    .gps-bar {
      display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap;
      padding: 1rem 0; border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border); margin-bottom: 2rem;
    }
    .gps-status {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 0.78rem; color: var(--text-muted);
    }
    .gps-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--text-dim); transition: background 0.3s;
    }
    .gps-dot.active { background: var(--green); }
    .gps-dot.error { background: var(--red); }
    .gps-dot.searching { animation: pulse 1s ease infinite; background: #d4a843; }

    .gps-radius {
      display: flex; align-items: center; gap: 0.5rem;
      font-size: 0.78rem; color: var(--text-muted);
    }
    .gps-radius strong { color: var(--text); font-weight: 500; }
    .gps-radius input[type="range"] { width: 100px; accent-color: var(--accent); }

    .gps-nearby {
      font-size: 0.78rem; color: var(--text-muted);
    }
    .gps-nearby strong { color: var(--text); font-weight: 500; }

    .gps-refresh {
      background: none; border: 1px solid var(--border);
      padding: 0.3rem 0.8rem; font-size: 0.72rem;
      color: var(--text-muted); cursor: pointer;
      transition: all 0.2s; font-family: inherit;
      letter-spacing: 0.05em;
    }
    .gps-refresh:hover { border-color: var(--accent); color: var(--accent); }

    .cam-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1px; background: var(--border); border: 1px solid var(--border);
    }
    .empty-state {
      grid-column: 1 / -1;
      text-align: center; padding: 3rem; color: var(--text-dim);
      font-size: 0.82rem; background: var(--surface);
    }

    .cam-card {
      background: var(--surface); overflow: hidden;
      transition: background 0.2s;
    }
    .cam-card:hover { background: #faf9f7; }
    .cam-preview {
      width: 100%; aspect-ratio: 16/9;
      background: #eae7e1; position: relative; overflow: hidden;
    }
    .cam-preview img, .cam-preview video {
      width: 100%; height: 100%; object-fit: cover;
      position: absolute; inset: 0;
    }
    .cam-nosig {
      display: flex; align-items: center; justify-content: center;
      height: 100%; color: var(--text-dim); font-size: 0.7rem;
      letter-spacing: 0.15em; font-family: var(--font-mono);
    }
    .cam-live {
      position: absolute; top: 10px; left: 10px; z-index: 2;
      background: rgba(255,255,255,0.88); backdrop-filter: blur(4px);
      padding: 2px 8px; font-size: 0.58rem; letter-spacing: 0.15em;
      color: var(--red); font-family: var(--font-mono); font-weight: 500;
    }
    .cam-dist {
      position: absolute; top: 10px; right: 10px; z-index: 2;
      background: rgba(255,255,255,0.88); backdrop-filter: blur(4px);
      padding: 2px 8px; font-size: 0.58rem; letter-spacing: 0.1em;
      color: var(--accent); font-family: var(--font-mono); font-weight: 500;
    }
    .cam-info { padding: 1rem 1.25rem; }
    .cam-name {
      font-size: 0.82rem; font-weight: 500;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      margin-bottom: 0.2rem;
    }
    .cam-city {
      font-size: 0.7rem; color: var(--text-dim);
      margin-bottom: 0.75rem;
    }
    .cam-actions { display: flex; gap: 0.5rem; }
    .cam-link {
      font-size: 0.7rem; color: var(--accent);
      letter-spacing: 0.05em; padding: 3px 0;
      border-bottom: 1px solid transparent; transition: border-color 0.2s;
    }
    .cam-link:hover { border-bottom-color: var(--accent); text-decoration: none; }

    .toast-container {
      position: fixed; bottom: 16px; right: 16px; max-width: 280px;
      display: flex; flex-direction: column; gap: 6px; z-index: 9999;
    }
    .toast {
      background: var(--surface); border: 1px solid var(--border);
      padding: 0.6rem 0.9rem; font-size: 0.78rem;
      animation: slideIn 0.2s ease;
      box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    }
    .toast-title { font-weight: 500; color: var(--text); margin-bottom: 2px; font-size: 0.8rem; }
    .toast-body { color: var(--text-dim); font-size: 0.7rem; }
    @keyframes slideIn {
      from { transform: translateY(8px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }
  </style>

  <script src="https://cdn.jsdelivr.net/npm/hls.js@1"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      var gpsDot = document.getElementById('gpsDot');
      var gpsText = document.getElementById('gpsText');
      var nearbyCount = document.getElementById('nearbyCount');
      var nearbyList = document.getElementById('nearbyList');
      var radiusSlider = document.getElementById('radiusSlider');
      var radiusLabel = document.getElementById('radiusLabel');
      var refreshBtn = document.getElementById('refreshBtn');
      var toastContainer = document.getElementById('toastContainer');

      var watchId = null;
      var currentPos = null;
      var allCameras = [];
      var lastNotified = {};
      var radius = 300;

      function deg2rad(d) { return d * (Math.PI / 180); }

      function haversineDist(lat1, lng1, lat2, lng2) {
        var R = 6371000;
        var dLat = deg2rad(lat2 - lat1);
        var dLng = deg2rad(lng2 - lng1);
        var a = Math.sin(dLat/2) * Math.sin(dLat/2) +
                Math.cos(deg2rad(lat1)) * Math.cos(deg2rad(lat2)) *
                Math.sin(dLng/2) * Math.sin(dLng/2);
        return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
      }

      function showToast(title, body) {
        var toast = document.createElement('div');
        toast.className = 'toast';
        toast.innerHTML = '<div class="toast-title">' + title + '</div><div class="toast-body">' + body + '</div>';
        toastContainer.appendChild(toast);
        setTimeout(function() { if (toast.parentNode) toast.remove(); }, 8000);
      }

      var cctvSvg = '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M23 7l-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>';

      function showNoSignal(el) {
        var d = document.createElement('div');
        d.className = 'cam-nosig';
        d.innerHTML = cctvSvg + '<span>NO SIGNAL</span>';
        el.replaceWith(d);
      }

      function renderCards(nearby) {
        if (nearby.length === 0) {
          nearbyList.innerHTML = '<div class="empty-state">検出範囲内にカメラがありません</div>';
          return;
        }
        nearbyList.innerHTML = nearby.map(function(cam) {
          var distStr = cam.dist < 1000 ? Math.round(cam.dist) + 'm' : (cam.dist/1000).toFixed(1) + 'km';
          var isHls = cam.type === 'hls' || (cam.url && cam.url.indexOf('.m3u8') !== -1);
          var media;
          if (isHls) {
            media = '<video class="cam-video" data-src="' + cam.url + '" muted autoplay loop playsinline></video>';
          } else {
            media = '<img class="cam-img" src="' + cam.url + '" alt="" loading="lazy" />';
          }
          return '' +
            '<div class="cam-card">' +
              '<div class="cam-preview">' +
                '<span class="cam-live">LIVE</span>' +
                '<span class="cam-dist">' + distStr + '</span>' +
                media +
              '</div>' +
              '<div class="cam-info">' +
                '<div class="cam-name">' + cam.name + '</div>' +
                '<div class="cam-city">' + (cam.city || '') + '</div>' +
                '<div class="cam-actions">' +
                  '<a href="' + cam.url + '" target="_blank" rel="noopener" class="cam-link">映像を見る</a>' +
                '</div>' +
              '</div>' +
            '</div>';
        }).join('');

        nearbyList.querySelectorAll('.cam-img').forEach(function(img) {
          img.onerror = function() { showNoSignal(img); };
        });

        var videos = nearbyList.querySelectorAll('.cam-video[data-src]');
        if (videos.length && typeof Hls !== 'undefined' && Hls.isSupported()) {
          videos.forEach(function(video) {
            var hls = new Hls({ enableWorker: true, lowLatencyMode: false, maxBufferLength: 10, startFragPrefetch: true });
            hls.loadSource(video.dataset.src);
            hls.attachMedia(video);
            hls.on(Hls.Events.MANIFEST_PARSED, function() { video.play().catch(function(){}); });
            hls.on(Hls.Events.ERROR, function(e, data) {
              if (data.fatal) { hls.destroy(); showNoSignal(video); }
            });
          });
        } else if (videos.length) {
          videos.forEach(function(video) {
            if (video.canPlayType('application/vnd.apple.mpegurl')) {
              video.src = video.dataset.src;
              video.play().catch(function(){});
            } else {
              showNoSignal(video);
            }
          });
        }
      }

      function updateNearby() {
        if (!currentPos || allCameras.length === 0) {
          nearbyList.innerHTML = '<div class="empty-state">位置情報を取得中...</div>';
          return;
        }

        var nearby = allCameras
          .map(function(cam) {
            var dist = haversineDist(currentPos.lat, currentPos.lng, cam.lat, cam.lng);
            var c = Object.assign({}, cam);
            c.dist = dist;
            return c;
          })
          .filter(function(cam) { return cam.dist <= radius; })
          .sort(function(a, b) { return a.dist - b.dist; });

        nearbyCount.textContent = nearby.length;

        nearby.forEach(function(cam) {
          var key = String(cam.id);
          if (!lastNotified[key]) {
            lastNotified[key] = true;
            var d = cam.dist < 1000 ? Math.round(cam.dist) + 'm' : (cam.dist/1000).toFixed(1) + 'km';
            showToast(cam.name, d + ' · ' + (cam.city || ''));
          }
        });

        renderCards(nearby);
      }

      async function loadAllCameras() {
        try {
          var resp = await fetch('/Live-CCTV/cameras_thumb.json');
          allCameras = await resp.json();
          updateNearby();
        } catch (e) {
          nearbyList.innerHTML = '<div class="empty-state">データ読込失敗</div>';
        }
      }

      function startWatching() {
        if (!('geolocation' in navigator)) {
          gpsDot.className = 'gps-dot error';
          gpsText.textContent = '位置情報非対応';
          return;
        }

        gpsDot.className = 'gps-dot searching';
        gpsText.textContent = '取得中...';

        watchId = navigator.geolocation.watchPosition(
          function(pos) {
            currentPos = { lat: pos.coords.latitude, lng: pos.coords.longitude };
            gpsDot.className = 'gps-dot active';
            gpsText.textContent = '位置確定';
            updateNearby();
          },
          function(err) {
            gpsDot.className = 'gps-dot error';
            gpsText.textContent = err.code === 1 ? '位置権限を許可してください' : '取得失敗';
          },
          { enableHighAccuracy: true, maximumAge: 5000, timeout: 15000 }
        );
      }

      radiusSlider.addEventListener('input', function() {
        radius = parseInt(radiusSlider.value);
        radiusLabel.textContent = radius;
        updateNearby();
      });

      refreshBtn.addEventListener('click', function() {
        if (watchId !== null) navigator.geolocation.clearWatch(watchId);
        lastNotified = {};
        startWatching();
      });

      loadAllCameras();
      startWatching();
    });
  </script>
</BaseLayout>
